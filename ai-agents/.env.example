# Copy to .env and fill in your keys.

# Anthropic Claude — enables LLM semantic analysis + parent explanations.
# Leave empty to run in heuristics-only fast mode (no LLM calls).
ANTHROPIC_API_KEY=
# Model to use. claude-opus-4-8 (default, most capable) or claude-haiku-4-5 (cheapest).
ANTHROPIC_MODEL=claude-opus-4-8

# Supabase (PostgreSQL) — optional. Enables result caching and the history page.
SUPABASE_URL=
SUPABASE_KEY=
